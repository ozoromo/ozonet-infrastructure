use flake

# The S3 backend (Scaleway Object Storage) reads AWS-style credentials.
# Mirror Scaleway creds so `tofu init` works without extra exports.
# Set SCW_ACCESS_KEY / SCW_SECRET_KEY in .envrc.local (gitignored).
export AWS_ACCESS_KEY_ID="${SCW_ACCESS_KEY:-}"
export AWS_SECRET_ACCESS_KEY="${SCW_SECRET_KEY:-}"
